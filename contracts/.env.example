# Deployer private key (with 0x prefix)
PRIVATE_KEY=0x...

# Optional: Etherscan API key for verification
ETHERSCAN_API_KEY=

# === Keepers (P1-A) ===

# Ethereum mainnet RPC — keyed provider (Alchemy/Infura free tier, К-8).
# Reads the Chainlink XAU/USD feed.
MAINNET_RPC_URL=

# Chainlink XAU/USD aggregator proxy on mainnet.
# Verified on-chain 2026-07-23: description() == "XAU / USD"
# (eth_call via ethereum-rpc.publicnode.com).
XAU_FEED_ADDRESS=0x214eD9Da11D2fbe465a6fc601a91E62EbEc1a0D6

# Canonical Attestors on zkSync Sepolia (docs/DEPLOYMENTS.md)
XAU_ATTESTOR_ADDRESS=0xe0AFc7eD0c6028b8172C2b108624168d235e8BFD
UZS_ATTESTOR_ADDRESS=0x637347fd661cFFAE9B562aFA394A392214fa24aD
RESERVE_ATTESTOR_ADDRESS=0x9413F60295dcf7D81fcb69eE256029900B107d1B

# Poster keys — ONE shared key per К-7 (three names, one value);
# POSTER_ROLE granted to it in P1-B. Until then the deployer key works
# (it already holds POSTER_ROLE on all three).
KEY_XAU=0x...
KEY_UZS=0x...
KEY_RESERVE=0x...

# Demo-bank reserve in grams (К-1: operator updates from the daily statement;
# К-3: 5 kg). A change beyond MAX_RESERVE_JUMP_BPS (default 10%) is refused
# unless RESERVE_CONFIRM is set to the exact new value.
RESERVE_GRAMS=5000
RESERVE_CONFIRM=

# Optional tuning (defaults shown, set only to override)
#HEARTBEAT_AGE=1800
#HEARTBEAT_AGE_UZS=86400
#MAX_SOURCE_AGE=259200
#SOURCE_WARN_AGE=82800
#MAX_CB_AGE_DAYS=7
#MAX_JUMP_BPS=1000
#MAX_RESERVE_JUMP_BPS=1000
#MIN_DELTA=0
#CBU_URL=https://cbu.uz/ru/arkhiv-kursov-valyut/json/USD/
#ZKSYNC_RPC_URL=https://sepolia.era.zksync.dev
