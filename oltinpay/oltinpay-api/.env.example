# Application
APP_NAME=OltinPay
DEBUG=true
API_V1_PREFIX=/api/v1

# Database (PostgreSQL + asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/oltinpay
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# CORS
CORS_ORIGINS=http://localhost:3000,https://app.oltinpay.com

# Blockchain — zkSync Era Sepolia (chainId 300), V3 contracts (docs/DEPLOYMENTS.md)
ZKSYNC_RPC_URL=https://sepolia.era.zksync.dev
ZKSYNC_CHAIN_ID=300
OLTIN_CONTRACT_ADDRESS=0x906bcf6c92ed1b30aA453c69eB40aeDbb3d5B3A5
UZD_CONTRACT_ADDRESS=0x95b30Be4fdE1C48d7C5dC22C1EBA061219125A32
STAKING_CONTRACT_ADDRESS=0x63e537A3a150d06035151E29904C1640181C8314
EXCHANGE_ADDRESS=0xc367D7761Cc2A1b4D15475017136085E3EF74e0C
RESERVE_ATTESTOR_ADDRESS=0x9413F60295dcf7D81fcb69eE256029900B107d1B
XAU_FEED_ADDRESS=0xe0AFc7eD0c6028b8172C2b108624168d235e8BFD
UZS_FEED_ADDRESS=0x637347fd661cFFAE9B562aFA394A392214fa24aD
# Legacy single admin key — retained for compatibility; PR-2 uses role keys.
ADMIN_PRIVATE_KEY=

# SignerPool role keys (each a distinct EOA — ONE writer per key; keep empty
# unless actively signing). Demo/testnet keys only; production uses KMS/HSM.
#   KEY_BANK_OPS  — UZD mint/burn (bank deposits, withdrawal confirms, welcome)
#   KEY_RESERVE   — ReserveAttestor.postAnswer (/bank/attestations)
#   KEY_UZS       — UzsUsdFeed.postAnswer (/bank/fx; keeper-uzs is retired)
#   KEY_XAU       — external keeper-xau ONLY (the API never signs XAU)
KEY_BANK_OPS=
KEY_RESERVE=
KEY_UZS=
KEY_XAU=

# Bank connector HMAC auth (shared secret with the bank client)
#   X-Bank-Signature = HMAC-SHA256(BANK_HMAC_SECRET, body + X-Bank-Timestamp + X-Bank-Nonce)
BANK_HMAC_SECRET=
BANK_HMAC_MAX_SKEW_SEC=300

# Chain indexer (simple last-N poller; not reorg-safe — testnet demo only)
INDEXER_ENABLED=true
INDEXER_POLL_SEC=15
INDEXER_LOOKBACK_BLOCKS=5000

# Aylin AI (znai-cloud)
ZNAI_CLOUD_URL=https://api.znai.cloud
ZNAI_CLOUD_API_KEY=your-znai-cloud-api-key
