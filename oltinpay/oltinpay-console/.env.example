# --- Public dashboard (server-side; the browser polls the same-origin /api/* proxy) ---
# Base URL of the OltinChain API (PR-2). Server-only — NOT exposed to the client.
API_URL=http://localhost:8000/api/v1

# --- Bank Panel (server-side signing layer, E2) ---
# HMAC secret shared with the API's BANK_HMAC_SECRET. Server-only — never sent
# to the browser. The panel's server route handlers sign requests with this.
BANK_HMAC_SECRET=

# Operator gate for /bank (E3, demo). Server-side check only. Use a non-trivial
# value — the panel drives real testnet mint/burn.
CONSOLE_OPERATOR_PASSWORD=
