# OltinPay — environment variables template
#
# Copy to `.env` on the server: `cp .env.example .env && chmod 600 .env`
# All variables below must be set before `docker compose up`.
#
# Do NOT commit a populated `.env`. The repo ignores it via `.gitignore`.
# ----------------------------------------------------------------------

# === CARRY-OVER from old /opt/oltinchain/.env on first migration ===
# Keep values to preserve existing JWT tokens & Telegram webhook.

SECRET_KEY=                       # JWT signing key
OLTINPAY_BOT_TOKEN=                # Telegram Bot API token (was TELEGRAM_BOT_TOKEN)

# === GENERATE on first migration (once) ===
# `openssl rand -hex 32` for each.

PG_PASSWORD=
REDIS_PASSWORD=

# === FROM USER (paste manually on server, never through CI) ===
# 0x-prefixed 64-hex private key for the admin wallet that signs welcome
# bonus mints on zkSync Sepolia. Rotated 2026-04-21.
# Address: 0xa0A78aA9B9619fbc3bC12b5756442BD7A7D6779e

ADMIN_PRIVATE_KEY=

# === OPTIONAL — Aylin AI assistant (leave empty to disable) ===

ZNAI_CLOUD_URL=
ZNAI_CLOUD_API_KEY=

# ----------------------------------------------------------------------
# DO NOT add the following — they are computed inside docker-compose.yml
# from PG_PASSWORD / REDIS_PASSWORD and should never appear in .env:
#   DATABASE_URL, REDIS_URL, CORS_ORIGINS_STR, TELEGRAM_BOT_TOKEN
# ----------------------------------------------------------------------
